# Google Drive Gallery (server-side only - never exposed to client)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Option A: Service Account (recommended - works reliably)
# 1. Create service account: https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Create JSON key, copy entire JSON
# 3. Share the Drive folder with the service account email (e.g. xxx@project.iam.gserviceaccount.com) as Editor
# 4. Paste JSON as single line (minified)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option B: API Key (public folder only, often 403)
# Folder must be "Anyone with the link can view"
# If 403, add resourceKey from folder URL: ?resourcekey=0-xxxx
GOOGLE_DRIVE_API_KEY=your_api_key_here
# GOOGLE_DRIVE_RESOURCE_KEY=0-xxxx  # Optional, from folder share URL
